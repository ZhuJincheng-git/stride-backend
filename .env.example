# App
APP_PORT=8080
APP_MODE=debug # debug | test | release

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=stride_db
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_IDLE=10
DB_MAX_OPEN=100
DB_CONN_MAX_LIFETIME_SECOND=3600

# Logging
LOG_LEVEL=info # debug | info | warn | error